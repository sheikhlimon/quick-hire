# Database
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority&tls=true

# CORS - Frontend URL (Render: https://your-frontend.onrender.com)
CORS_ORIGIN=http://localhost:3001

# JWT Secret (Generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Environment
NODE_ENV=development

# Port (Render will set PORT automatically, defaults to 3000)
PORT=3000
