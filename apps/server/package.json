{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "node ../../node_modules/tsdown/dist/run.mjs",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "npx turbo -F @quick-hire/db db:push --skip-generate && node dist/index.mjs",
    "start:no-db": "node dist/index.mjs",
    "seed": "tsx scripts/seed.ts",
    "prepare": "[ -d .git ] && husky || true"
  },
  "dependencies": {
    "@quick-hire/db": "*",
    "@quick-hire/env": "*",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@quick-hire/config": "*",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.14",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
